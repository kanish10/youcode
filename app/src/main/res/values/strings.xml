    <!-- Grounding exercise -->
    <string name="grounding_see">Name 5 things you can see</string>
    <string name="grounding_touch">Name 4 things you can touch</string>
    <string name="grounding_hear">Name 3 things you can hear</string>
    <string name="grounding_smell">Name 2 things you can smell</string>
    <string name="grounding_taste">Name 1 thing you can taste</string>
    <string name="grounding_safe">You are here. You are safe. You are present.</string>
    <string name="grounding_hero_badge">Quiet grounding</string>
    <string name="grounding_hero_title">Return to what is steady around you</string>
    <string name="grounding_hero_body">This 5-4-3-2-1 flow brings attention back to the room, one sense at a time. There is no perfect answer here. Noticing even one thing is enough.</string>
    <string name="grounding_step_see_body">Look around slowly and notice five shapes, colors, or pieces of light that are here with you.</string>
    <string name="grounding_step_touch_body">Find four textures or surfaces nearby. You can rest your hand on something if that feels easier.</string>
    <string name="grounding_step_hear_body">Pause and listen for three sounds, even if they are quiet, far away, or only present for a moment.</string>
    <string name="grounding_step_smell_body">Notice two scents in the air, on your clothes, or in the room. If nothing stands out, simply notice the temperature of the air.</string>
    <string name="grounding_step_taste_body">Notice one taste in your mouth, a sip of water, or even the absence of taste. Gentle noticing still counts.</string>
